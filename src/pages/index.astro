---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import PostCard from "../components/PostCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const allPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const others = allPosts.filter(p => p.id !== featured.id);
---

<BaseLayout title="Aathila Thasneem — Microbiologist & Writer">
  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-16 md:pt-20 pb-14 md:pb-20">
    <div class="mb-12 flex items-baseline justify-between">
      <div>
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">The Cultured Crew</p>
        <h2 class="mt-2 font-[var(--font-display)] text-2xl md:text-3xl text-[var(--color-ink)] font-medium italic">
          Notes on microbes, food, and life from a Chennai lab.
        </h2>
      </div>
      <a href={`${base}/writing`} class="hidden md:inline-flex no-underline text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-accent-deep)]">
        All writing →
      </a>
    </div>

    <FeaturedPost
      href={`${base}/writing/${featured.id}`}
      title={featured.data.title}
      description={featured.data.description}
      date={featured.data.date}
      category={featured.data.category}
      heroImage={featured.data.heroImage}
      heroAlt={featured.data.heroAlt}
    />
  </section>

  {others.length > 0 && (
    <section class="mx-auto max-w-[var(--container-wide)] px-6 pb-20 border-t border-[var(--color-rule)] pt-16">
      <div class="mb-10 flex items-baseline justify-between">
        <h2 class="text-2xl text-[var(--color-ink)] font-medium">More from the blog</h2>
        <a href={`${base}/writing`} class="no-underline text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-accent-deep)]">
          View archive →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
        {others.map(post => (
          <PostCard
            href={`${base}/writing/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            heroImage={post.data.heroImage}
            heroAlt={post.data.heroAlt}
          />
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-[var(--container-wide)] px-6 pb-24 border-t border-[var(--color-rule)] pt-16">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5">
        <div class="overflow-hidden rounded-xl aspect-square bg-gradient-to-br from-[var(--color-accent-soft)] to-[var(--color-blush)]">
          <img src={`${base}/images/aathila-portrait.jpg`} alt="Aathila at her microbiology lab — illustration" class="h-full w-full object-cover" />
        </div>
      </div>
      <div class="md:col-span-7">
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">About</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-medium text-[var(--color-ink)] leading-tight">
          Hi, I'm Aathila — a microbiology master's student in Chennai.
        </h2>
        <p class="mt-5 text-lg text-[var(--color-ink-soft)] leading-relaxed">
          I'm fascinated by the tiny creatures that rule our world. From the gut-wrenching drama of
          antibiotic resistance to the mind-blowing magic of microbial symbiosis, there's never a dull
          moment in the microbial realm. When I'm not pipetting, I'm here — sharing what I find.
        </p>
        <div class="mt-7 flex flex-wrap gap-4">
          <a href={`${base}/about`} class="no-underline inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-ink)] text-white text-sm font-medium hover:bg-[var(--color-accent-deep)] transition-colors">
            Read more about me
          </a>
          <a href={`${base}/cv`} class="no-underline inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-[var(--color-rule)] text-[var(--color-ink)] text-sm font-medium hover:border-[var(--color-accent)] transition-colors">
            View CV
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
