---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Citrus limon as a Natural Antifungal Agent in Food Products",
    blurb: "Investigated whether Citrus limon extracts can stand in for synthetic preservatives by inhibiting food-spoilage fungi — a step toward natural alternatives in food preservation.",
    highlights: [
      "Evaluated antifungal activity against food-spoilage fungi",
      "Assessed potential as a natural food-preservative alternative",
      "Microbiological culture techniques and zone-of-inhibition assays",
    ],
    tag: "Antifungal",
  },
  {
    title: "Formulation of Probiotic Beetroot Drink",
    blurb: "Developed a functional beverage using Lactobacillus plantarum, with a focus on probiotic survival, pathogen inhibition, and nutritional enhancement.",
    highlights: [
      "Lactobacillus plantarum probiotic survival studies",
      "Pathogen inhibition assays",
      "Functional beverage formulation",
    ],
    tag: "Probiotics",
  },
  {
    title: "Coconut Water-Based Functional Beverage",
    blurb: "Explored coconut water as a base for a functional probiotic drink — testing microbial viability, stability, and quality across storage conditions.",
    highlights: [
      "Probiotic viability in coconut water medium",
      "Microbial stability over storage time",
      "Beverage preservation & quality parameters",
    ],
    tag: "Functional foods",
  },
];

const publication = {
  title: "Conservation of Natural Resources",
  venue: "Environment and Climatic Changes — Volume I",
  isbn: "ISBN: 978-93-94638-83-9",
};
---

<BaseLayout title="Research — Aathila Thasneem" description="Research projects in food microbiology, probiotics and natural antimicrobials by Aathila Thasneem.">
  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-16 md:pt-20">
    <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">Lab Notes</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-medium text-[var(--color-ink)] leading-tight">
      Research
    </h1>
    <p class="mt-5 text-lg text-[var(--color-ink-soft)] leading-relaxed max-w-prose">
      Projects from my M.Sc. and B.Sc. work — mostly at the intersection of food microbiology,
      probiotics, and natural antimicrobials.
    </p>
  </section>

  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-12 pb-12">
    <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-6">
      {projects.map(p => (
        <article class="group p-7 rounded-2xl border border-[var(--color-rule)] bg-[var(--color-paper)] hover:border-[var(--color-accent)] transition-colors flex flex-col">
          <span class="self-start text-[0.7rem] uppercase tracking-[0.18em] px-2.5 py-1 rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-deep)] font-medium">
            {p.tag}
          </span>
          <h2 class="mt-5 text-xl font-medium text-[var(--color-ink)] leading-snug">
            {p.title}
          </h2>
          <p class="mt-3 text-[var(--color-ink-soft)] text-[0.95rem] leading-relaxed">
            {p.blurb}
          </p>
          <ul class="mt-5 space-y-2 text-sm text-[var(--color-ink-soft)] border-t border-[var(--color-rule)] pt-4">
            {p.highlights.map(h => (
              <li class="flex gap-2">
                <span class="text-[var(--color-accent-deep)] mt-1">•</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[var(--container-wide)] px-6 py-12 border-t border-[var(--color-rule)]">
    <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">Publication</p>
    <div class="mt-4 p-7 rounded-2xl border border-[var(--color-rule)] bg-[var(--color-paper)] max-w-2xl">
      <h3 class="text-xl font-medium text-[var(--color-ink)]">{publication.title}</h3>
      <p class="mt-2 text-[var(--color-ink-soft)] italic">{publication.venue}</p>
      <p class="mt-3 text-sm text-[var(--color-ink-mute)] font-mono">{publication.isbn}</p>
    </div>
  </section>
</BaseLayout>
