---
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  { label: "Email", value: "aathilathasneem121@gmail.com", href: "mailto:aathilathasneem121@gmail.com", note: "the best way to reach me" },
  { label: "LinkedIn", value: "Aathila Thasneem", href: "https://www.linkedin.com/in/aathila-thasneem-a11a71295", note: "research, opportunities & professional inquiries" },
];
---

<BaseLayout title="Contact — Aathila Thasneem" description="Get in touch with Aathila Thasneem — email, LinkedIn, and where to find her writing.">
  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-16 md:pt-24 pb-24">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-5">
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">Say hello</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-medium text-[var(--color-ink)] leading-tight">
          Let's talk about microbes — or anything else.
        </h1>
        <p class="mt-6 text-lg text-[var(--color-ink-soft)] leading-relaxed">
          I love hearing from readers, fellow students, and anyone curious about the work I do.
          Reach out by email or LinkedIn — I'll get back to you.
        </p>
      </div>

      <div class="md:col-span-7 space-y-4">
        {links.map(l => (
          <a href={l.href} target={l.href.startsWith("http") ? "_blank" : undefined} rel="noopener" class="no-underline group block p-6 rounded-2xl border border-[var(--color-rule)] bg-[var(--color-paper)] hover:border-[var(--color-accent)] transition-colors">
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="text-[0.7rem] uppercase tracking-[0.2em] text-[var(--color-ink-mute)]">{l.label}</div>
                <div class="mt-2 text-lg font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent-deep)] transition-colors">
                  {l.value}
                </div>
                <div class="mt-1 text-sm text-[var(--color-ink-soft)]">{l.note}</div>
              </div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-ink-mute)] group-hover:text-[var(--color-accent-deep)] transition-colors">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
