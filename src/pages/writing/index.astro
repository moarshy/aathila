---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const allPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const science = allPosts.filter(p => p.data.category === "Science");
const personal = allPosts.filter(p => p.data.category === "Personal");
---

<BaseLayout title="Writing — Aathila Thasneem" description="Essays on microbes, food, and life from Aathila Thasneem.">
  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-16 md:pt-20">
    <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-ink-mute)]">The Cultured Crew</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-medium text-[var(--color-ink)] leading-tight">
      Writing
    </h1>
    <p class="mt-5 text-lg text-[var(--color-ink-soft)] leading-relaxed max-w-prose">
      Essays from inside the lab and outside of it — some about microbes, some about the rest of life.
    </p>

    <div class="mt-10 flex gap-3" id="filter-bar">
      <button data-filter="all" class="filter-btn px-4 py-1.5 rounded-full bg-[var(--color-ink)] text-white text-sm">All ({allPosts.length})</button>
      <button data-filter="Science" class="filter-btn px-4 py-1.5 rounded-full border border-[var(--color-rule)] text-[var(--color-ink-soft)] text-sm hover:border-[var(--color-accent)]">Science ({science.length})</button>
      <button data-filter="Personal" class="filter-btn px-4 py-1.5 rounded-full border border-[var(--color-rule)] text-[var(--color-ink-soft)] text-sm hover:border-[var(--color-accent)]">Personal ({personal.length})</button>
    </div>
  </section>

  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-12 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14" id="posts-grid">
      {allPosts.map(post => (
        <div data-category={post.data.category}>
          <PostCard
            href={`${base}/writing/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            heroImage={post.data.heroImage}
            heroAlt={post.data.heroAlt}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const buttons = document.querySelectorAll(".filter-btn");
  const items = document.querySelectorAll("#posts-grid > [data-category]");
  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const filter = btn.getAttribute("data-filter");
      buttons.forEach(b => {
        b.classList.remove("bg-[var(--color-ink)]", "text-white");
        b.classList.add("border", "border-[var(--color-rule)]", "text-[var(--color-ink-soft)]");
      });
      btn.classList.add("bg-[var(--color-ink)]", "text-white");
      btn.classList.remove("border", "border-[var(--color-rule)]", "text-[var(--color-ink-soft)]");
      items.forEach(item => {
        if (filter === "all" || item.getAttribute("data-category") === filter) {
          item.style.display = "";
        } else {
          item.style.display = "none";
        }
      });
    });
  });
</script>
