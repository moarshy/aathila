---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  category: "Science" | "Personal";
  heroImage?: string;
  heroAlt?: string;
  readingMinutes?: number;
}

const { href, title, description, date, category, heroImage, heroAlt, readingMinutes } = Astro.props;
const fmt = new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(date);
---

<a href={href} class="no-underline group block">
  <div class="grid md:grid-cols-12 gap-8 lg:gap-12 items-center">
    <div class="md:col-span-7 order-2 md:order-1">
      <div class="flex items-center gap-3 text-[0.72rem] uppercase tracking-[0.2em] text-[var(--color-ink-mute)]">
        <span class={`px-2 py-0.5 rounded ${category === "Science" ? "bg-[var(--color-accent-soft)] text-[var(--color-accent-deep)]" : "bg-[var(--color-blush)]/60 text-[#9d174d]"}`}>
          {category}
        </span>
        <span>Featured</span>
        <span class="text-[var(--color-rule)]">/</span>
        <span>{fmt}</span>
      </div>
      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl leading-[1.08] text-[var(--color-ink)] font-medium tracking-tight group-hover:text-[var(--color-accent-deep)] transition-colors">
        {title}
      </h1>
      <p class="mt-5 text-lg text-[var(--color-ink-soft)] leading-relaxed max-w-prose">
        {description}
      </p>
      <div class="mt-6 inline-flex items-center gap-2 text-sm text-[var(--color-accent-deep)] font-medium">
        Read essay
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
    </div>
    <div class="md:col-span-5 order-1 md:order-2">
      <div class="relative overflow-hidden rounded-xl aspect-[5/4] bg-gradient-to-br from-[var(--color-accent-soft)] via-[#dbeafe] to-[var(--color-blush)]">
        {heroImage ? (
          <img
            src={heroImage}
            alt={heroAlt ?? title}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-[var(--color-ink)]/25 font-[var(--font-display)] text-8xl italic">🧫</div>
          </div>
        )}
      </div>
    </div>
  </div>
</a>
