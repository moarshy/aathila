---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(base, "") || "/";

const nav = [
  { label: "Writing", href: `${base}/writing` },
  { label: "About", href: `${base}/about` },
  { label: "Research", href: `${base}/research` },
  { label: "CV", href: `${base}/cv` },
  { label: "Contact", href: `${base}/contact` },
];

const isActive = (href: string) => {
  const stripped = href.replace(base, "") || "/";
  if (stripped === "/") return path === "/";
  return path.startsWith(stripped);
};
---

<header class="border-b border-[var(--color-rule)] bg-[var(--color-canvas)]/85 backdrop-blur sticky top-0 z-30">
  <div class="mx-auto max-w-[var(--container-wide)] px-6 py-5 flex items-center justify-between gap-6">
    <a href={`${base}/`} class="group no-underline">
      <div class="font-[var(--font-display)] text-[1.35rem] leading-none tracking-tight text-[var(--color-ink)] font-medium">
        Aathila Thasneem
      </div>
      <div class="text-[0.72rem] uppercase tracking-[0.18em] text-[var(--color-ink-mute)] mt-1">
        Microbiologist · Chennai
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-7 text-[0.92rem]">
      {nav.map(item => (
        <a
          href={item.href}
          class={`no-underline transition-colors ${
            isActive(item.href)
              ? "text-[var(--color-accent-deep)] font-medium"
              : "text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]"
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button
      id="menu-toggle"
      class="md:hidden text-[var(--color-ink)] p-2 -mr-2"
      aria-label="Open menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
  <nav id="mobile-nav" class="md:hidden hidden border-t border-[var(--color-rule)] bg-[var(--color-paper)]">
    <div class="mx-auto max-w-[var(--container-wide)] px-6 py-4 flex flex-col gap-3">
      {nav.map(item => (
        <a href={item.href} class="no-underline text-[var(--color-ink-soft)] py-1">{item.label}</a>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  const btn = document.getElementById("menu-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  btn?.addEventListener("click", () => mobileNav?.classList.toggle("hidden"));
</script>
