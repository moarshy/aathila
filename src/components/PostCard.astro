---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  category: "Science" | "Personal";
  heroImage?: string;
  heroAlt?: string;
  variant?: "default" | "compact";
}

const { href, title, description, date, category, heroImage, heroAlt, variant = "default" } = Astro.props;

const fmt = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);

const gradientByCategory = {
  Science: "bg-gradient-to-br from-[var(--color-accent-soft)] via-[#dbeafe] to-[var(--color-blush)]",
  Personal: "bg-gradient-to-br from-[var(--color-blush)] via-[#fef3c7] to-[var(--color-accent-soft)]",
};
---

<article class="group">
  <a href={href} class="no-underline block">
    <div class={`relative overflow-hidden rounded-lg ${heroImage ? "" : gradientByCategory[category]} aspect-[4/3]`}>
      {heroImage ? (
        <img
          src={heroImage}
          alt={heroAlt ?? title}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-[var(--color-ink)]/30 font-[var(--font-display)] text-5xl italic">
            {category === "Science" ? "🧫" : "✦"}
          </div>
        </div>
      )}
    </div>
    <div class="mt-4">
      <div class="flex items-center gap-3 text-[0.72rem] uppercase tracking-[0.18em] text-[var(--color-ink-mute)]">
        <span class={`px-2 py-0.5 rounded ${category === "Science" ? "bg-[var(--color-accent-soft)] text-[var(--color-accent-deep)]" : "bg-[var(--color-blush)]/60 text-[#9d174d]"}`}>
          {category}
        </span>
        <span>{fmt}</span>
      </div>
      <h3 class={`mt-3 ${variant === "compact" ? "text-lg" : "text-xl"} text-[var(--color-ink)] leading-snug font-medium group-hover:text-[var(--color-accent-deep)] transition-colors`}>
        {title}
      </h3>
      {variant === "default" && (
        <p class="mt-2 text-[var(--color-ink-soft)] text-[0.95rem] leading-relaxed line-clamp-2">
          {description}
        </p>
      )}
    </div>
  </a>
</article>
